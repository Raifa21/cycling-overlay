{
    "version": 1,
    "canvas": { "width": 1920, "height": 1080, "fps": 30 },
    "units": { "speed": "kmh", "distance": "km", "elevation": "m", "temp": "c" },
    "theme": {
        "font": "Inter",
        "fg": "#ffffff",
        "accent": "#00cccc",
        "shadow": null
    },
    "rider": { "weight_kg": 55.0 },
    "widgets": [
        {
            "type": "readout", "id": "power_readout",
            "metric": "power",
            "rect": { "x": 300, "y": 760, "w": 280, "h": 140 },
            "label": "POWER", "decimals": 0, "font_size": 80.0,
            "unit_font_size": 32.0
        },
        {
            "type": "readout", "id": "wkg_readout",
            "metric": "w_per_kg",
            "rect": { "x": 300, "y": 900, "w": 280, "h": 140 },
            "label": "W/KG", "decimals": 1, "font_size": 80.0,
            "unit_font_size": 32.0
        },
        {
            "type": "readout", "id": "hr_readout",
            "metric": "heart_rate",
            "rect": { "x": 300, "y": 620, "w": 280, "h": 140 },
            "label": "HR", "decimals": 0, "font_size": 80.0,
            "unit_font_size": 32.0
        },
        {
            "type": "readout", "id": "distance_readout",
            "metric": "distance",
            "rect": { "x": 300, "y": 480, "w": 280, "h": 140 },
            "label": "DIST", "decimals": 2, "font_size": 80.0,
            "unit_font_size": 32.0
        },
        {
            "type": "readout", "id": "speed_readout",
            "metric": "speed",
            "rect": { "x": 300, "y": 340, "w": 280, "h": 140 },
            "label": "SPEED", "decimals": 1, "font_size": 80.0,
            "unit_font_size": 32.0
        },
        {
            "type": "readout", "id": "cadence_readout",
            "metric": "cadence",
            "rect": { "x": 1580, "y": 340, "w": 280, "h": 140 },
            "label": "CAD", "decimals": 0, "font_size": 80.0,
            "unit_font_size": 32.0
        },
        {
            "type": "readout", "id": "time_elapsed_readout",
            "metric": "time_elapsed",
            "rect": { "x": 1580, "y": 480, "w": 280, "h": 140 },
            "label": "TIME", "decimals": 0, "font_size": 80.0,
            "unit_font_size": 32.0
        },
        {
            "type": "readout", "id": "elev_gain_readout",
            "metric": "elev_gain",
            "rect": { "x": 1580, "y": 620, "w": 280, "h": 140 },
            "label": "ELEV", "decimals": 0, "font_size": 80.0,
            "unit_font_size": 32.0
        },
        {
            "type": "bar", "id": "distance_bar",
            "metric": "distance",
            "rect": { "x": 50, "y": 260, "w": 1460, "h": 40 },
            "show_text": true,
            "decimals": 2
        },
        {
            "type": "course", "id": "course_map",
            "rect": { "x": 1560, "y": 60, "w": 300, "h": 300 },
            "line_width": 4.0,
            "dot_radius": 8.0
        },
        {
            "type": "elevation_profile", "id": "elev_profile",
            "rect": { "x": 50, "y": 60, "w": 1460, "h": 180 }
        },
        {
            "type": "meter", "id": "speed_meter",
            "metric": "speed",
            "rect": { "x": 40, "y": 360, "w": 60, "h": 650 },
            "min": 0.0, "max": 50.0,
            "orientation": "vertical",
            "indicator": { "kind": "needle", "fill_under": true },
            "ticks": { "show_numbers": true, "decimals": 0 },
            "show_value": true
        },        
        {
            "type": "meter", "id": "power_meter",
            "metric": "power",
            "rect": { "x": 160, "y": 360, "w": 60, "h": 650 },
            "min": 0.0, "max": 600.0,
            "orientation": "vertical",
            "indicator": { "kind": "arrow", "fill_under": true },
            "ticks": { "show_numbers": true, "decimals": 0 },
            "show_value": true
        },
        {
            "type": "gauge", "id": "power_gauge",
            "metric": "power",
            "rect": { "x": 1580, "y": 760, "w": 280, "h": 280 },
            "min": 0.0, "max": 1200.0,
            "indicator": { "kind": "needle", "fill_under": true },
            "ticks": { "show_numbers": true, "decimals": 0 },
            "show_value": true
        }
    ]
}
